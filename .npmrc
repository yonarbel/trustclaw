public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*

# Always resolve from the public npm registry, regardless of what global
# pnpm/npm config (e.g. Zscaler / corporate proxy) is set on the dev machine.
# This protects the lockfile from getting tarball URLs rewritten to a
# private registry that CI (Vercel) cannot authenticate against.
registry=https://registry.npmjs.org/